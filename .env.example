# ── Dropbox ──────────────────────────────────────────────────────────────────
# Create an app at https://www.dropbox.com/developers/apps
# Generate an access token under "OAuth 2" → "Generated access token"
DROPBOX_ACCESS_TOKEN=your_dropbox_token_here
DROPBOX_FOLDER_PATH=/LinkedInContent

# ── Google Gemini AI ─────────────────────────────────────────────────────────
# Get your API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Gmail ────────────────────────────────────────────────────────────────────
# Use a Gmail App Password (NOT your regular password)
# 1. Enable 2-Step Verification: https://myaccount.google.com/security
# 2. Create App Password: https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
EMAIL_RECIPIENT=you@gmail.com

# ── Voice / Persona (optional) ──────────────────────────────────────────────
# Customize how the AI writes your LinkedIn posts.
# Leave blank to use the default professional tone.
LINKEDIN_PERSONA=You are writing LinkedIn posts for [Your Name], a [your role] who is passionate about [topics]. Write in a [tone] voice. Use short paragraphs and line breaks.
